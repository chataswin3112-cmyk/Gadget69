# Shared local env file for Vite + Spring Boot.
# The backend auto-loads `.env`, `.env.local`, `backend/.env`, and `backend/.env.local`
# when you run it locally. Only `VITE_*` vars are exposed to the browser.
VITE_API_BASE_URL=/api

# Razorpay
APP_RAZORPAY_ENABLED=false
APP_RAZORPAY_KEY_ID=
APP_RAZORPAY_KEY_SECRET=
APP_RAZORPAY_WEBHOOK_SECRET=
